generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dipendente {
  id        String   @id @default(cuid())
  email     String?  // opzionale; login con nome + cognome + password
  password  String
  nome      String
  cognome   String
  role      String   @default("DIPENDENTE") // DIPENDENTE | ADMIN | RESPONSABILE_CANTIERE
  createdAt DateTime @default(now())
  timbrature Timbratura[]
  cantieriResponsabile Cantiere[]       @relation("ResponsabileCantiere")
  assegnazioni AssegnazioneCantiere[]
  rapportiniCreati Rapportino[]
  @@unique([nome, cognome])
}

model Cantiere {
  id             String   @id @default(cuid())
  nome           String
  indirizzo      String?
  responsabileId String?
  responsabile   Dipendente? @relation("ResponsabileCantiere", fields: [responsabileId], references: [id], onDelete: SetNull)
  timbrature     Timbratura[]
  assegnazioni   AssegnazioneCantiere[]
  rapportini     Rapportino[]
  @@map("Cantiere")
}

model AssegnazioneCantiere {
  id           String   @id @default(cuid())
  dipendenteId String
  cantiereId   String
  dataInizio   DateTime // lunedì della settimana
  dataFine     DateTime // domenica della settimana
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  cantiere     Cantiere  @relation(fields: [cantiereId], references: [id], onDelete: Cascade)
  @@unique([dipendenteId, cantiereId, dataInizio])
  @@map("AssegnazioneCantiere")
}

model Timbratura {
  id          String   @id @default(cuid())
  tipo        String   // "ENTRATA" | "USCITA"
  latitudine  Float
  longitudine Float
  indirizzo   String?  // da reverse geocoding
  citta      String?  // città da reverse geocoding
  createdAt   DateTime @default(now())
  dipendenteId String
  cantiereId   String?
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  cantiere     Cantiere?  @relation(fields: [cantiereId], references: [id], onDelete: SetNull)
}

model Rapportino {
  id                 String   @id @default(cuid())
  data               DateTime // giorno (o inizio periodo se dataFine presente)
  dataFine           DateTime? // se presente = rapportino di periodo dal data al dataFine
  cantiereId         String
  responsabileId     String   // chi ha generato
  descrizioneLavori  String?  @db.Text
  firmaResponsabile  String?  @db.Text // base64 image
  firmaVisore        String?  @db.Text // base64 image
  righe              Json     // giornaliero: RigaRapportino[]; periodo: { giorni: { data, righe }[] }
  createdAt          DateTime @default(now())
  cantiere           Cantiere  @relation(fields: [cantiereId], references: [id], onDelete: Cascade)
  responsabile       Dipendente @relation(fields: [responsabileId], references: [id], onDelete: Cascade)
  @@map("Rapportino")
}
